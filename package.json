{
  "name": "mybutler",
  "version": "1.0.0",
  "private": true,
  "description": "生活管理Webアプリ - メモ・LINE通知・サブスク管理",
  "scripts": {
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:detector": "cd services/subscription_detector && python app.py",
    "dev:notification": "cd services/notification && python scheduler.py",
    "init-db": "cd backend && npm run init-db"
  }
}
