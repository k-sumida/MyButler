PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-in-production
DB_PATH=../data/mybutler.db

# Supabase を使う場合（設定時は SQLite より優先）
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

CORS_ORIGIN=http://localhost:5173

# アレルギー給食 OCR（推奨）Google Cloud Vision サービスアカウント JSON
GOOGLE_CLOUD_VISION_CREDENTIALS={"type":"service_account","project_id":"..."}

# フォールバック OCR（任意）https://ocr.space/ocrapi
OCR_SPACE_API_KEY=your-ocr-space-api-key
