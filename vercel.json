{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "frontend/dist",
  "installCommand": "npm install && npm install --prefix frontend",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/cron/notify.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/((?!cron/).*)", "destination": "/api" },
    { "source": "/((?!api/|favicon\\.svg|favicon\\.ico|assets/|manage/).*)", "destination": "/index.html" }
  ]
}
