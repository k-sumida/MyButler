# Vercel ダッシュボード > Settings > Environment Variables に設定

# 必須: JWT 署名用（ランダムな長い文字列）
JWT_SECRET=your-production-jwt-secret

# 必須: Supabase PostgreSQL 接続文字列
# 取得手順は下記「Supabase 接続文字列の見つけ方」を参照
# Vercel では Transaction pooler（port 6543）を使用
# ユーザー名は postgres ではなく postgres.[project-ref] 形式
# パスワードに @ # などが含まれる場合は URL エンコードが必要
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true

# LINE 通知（任意）
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# アレルギー給食 OCR（推奨: Google Cloud Vision・日本語に強い）
# 1. https://console.cloud.google.com でプロジェクト作成
# 2. 「Cloud Vision API」を有効化
# 3. IAM > サービスアカウント作成 > キー(JSON)をダウンロード
# 4. 下記に JSON 全文を1行で貼り付け（Vercel の Environment Variables）
GOOGLE_CLOUD_VISION_CREDENTIALS={"type":"service_account","project_id":"..."}

# Document AI Layout Parser（献立表の表形式整形）
# Layout Parser は作成時に us または eu のみ選択可能
# 1. https://console.cloud.google.com/ai/document-ai/processors で Layout Parser を作成
# 2. リージョン: us（推奨）または eu
# 3. 「Cloud Document AI API」を有効化
# 4. プロセッサ ID を下記に設定（作成したリージョンと一致させる）
GOOGLE_DOCUMENT_AI_LOCATION=us
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=your-processor-id

# フォールバック OCR（任意）https://ocr.space/ocrapi
OCR_SPACE_API_KEY=your-ocr-space-api-key

# 通知 API 保護用（必須推奨）
# GitHub Actions や cron-job.org から Authorization ヘッダーで送る
CRON_SECRET=your-random-cron-secret

# ── LINE 通知の定期実行（cron-job.org 推奨）──
# 1. https://cron-job.org でアカウント作成
# 2. Create cronjob:
#      URL    = https://your-app.vercel.app/api/cron/notify
#      Method = GET
#      Header = Authorization: Bearer （上の CRON_SECRET と同じ値）
#      Schedule = 5分ごと（*/5 * * * *）
# 3. 手動テストは GitHub Actions → LINE Notify → Run workflow でも可

# ── Supabase 接続文字列の見つけ方 ──
# 1. https://supabase.com/dashboard にログイン
# 2. 対象プロジェクトを開く（組織設定ではなくプロジェクト画面）
# 3. 画面上部の「Connect」ボタンをクリック
# 4. 「Transaction pooler」または「ORMs / Prisma」などの項目から URI をコピー
#    ※ Vercel 向けは port 6543 の Transaction pooler
# 5. [YOUR-PASSWORD] を DB パスワードに置き換える
#
# パスワード不明の場合:
# 左サイドバー 歯車アイコン > Database > Database password > Reset password
